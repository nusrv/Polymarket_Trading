# Polymarket FastLoop Trader — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# --- Required ---

# Simmer API key — get from simmer.markets/dashboard → SDK tab
SIMMER_API_KEY=your-simmer-api-key-here

# Polymarket wallet private key — required for live trading
# The SDK uses this to sign orders client-side automatically
# This is the private key of the wallet that holds your USDC.e on Polygon
WALLET_PRIVATE_KEY=0xyour-wallet-private-key-here

# PostgreSQL database URL — injected automatically by Railway when you add a Postgres plugin
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://user:password@host:5432/dbname

# Flask dashboard port — injected automatically by Railway
# Do not set this manually in production; Railway controls it
PORT=8080

# Trading mode label shown on dashboard (paper or live)
TRADING_MODE=paper

# --- Optional overrides (can also be set in config.json or via --set) ---

# Minimum price divergence from 50¢ to trigger a trade (default: 0.05)
# SIMMER_SPRINT_ENTRY=0.05

# Minimum BTC/ETH/SOL % move to consider (default: 0.5)
# SIMMER_SPRINT_MOMENTUM=0.5

# Maximum $ per trade (default: 5.0)
# SIMMER_SPRINT_MAX_POSITION=5.0

# Price feed source: binance or coingecko (default: binance)
# SIMMER_SPRINT_SIGNAL=binance

# Minutes of price history to use for momentum (default: 5)
# SIMMER_SPRINT_LOOKBACK=5

# Skip markets with less than this many seconds remaining (default: 60)
# SIMMER_SPRINT_MIN_TIME=60

# Asset to trade: BTC, ETH, or SOL (default: BTC)
# SIMMER_SPRINT_ASSET=BTC

# Market window: 5m or 15m (default: 5m)
# SIMMER_SPRINT_WINDOW=5m

# Weight signal by Binance volume ratio (default: true)
# SIMMER_SPRINT_VOL_CONF=true

# Maximum daily spend in USD (default: 50.0)
# SIMMER_SPRINT_DAILY_BUDGET=50.0
